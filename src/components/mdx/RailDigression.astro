---
export interface Props {
  label?: string
  note: string
  class?: string
}

const { label, note, class: className } = Astro.props

if (!note?.trim()) {
  throw new Error('RailDigression requires a non-empty note prop')
}
---

<div class:list={['post__rail-digression', className]}>
  <div class="post__rail-digression-source">
    <slot />
  </div>
  <aside
    class="post__rail-digression-note"
    aria-label={label || 'Digression note'}
  >
    {label && <p class="post__rail-digression-label">{label}</p>}
    <p>{note}</p>
  </aside>
</div>
