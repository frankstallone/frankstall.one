---
import { getCollection, render } from 'astro:content'
import InnerLayout from '../../layouts/InnerLayout.astro'
import Likes from '@components/Likes.astro'
import { buildHierarchy } from '@utils/index'
import FloatingTableOfContents from '@components/FloatingTableOfContents.astro'
import TableOfContents from '@components/TableOfContents.astro'
import { mdxComponents } from '@components/mdx'
import { Like } from 'db/schema'
import { db } from 'src/turso'
import { count, eq } from 'drizzle-orm'

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog')
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props

let postLikesCount = 0
if (db) {
  try {
    const [{ count: countVal }] = await db
      .select({ count: count() })
      .from(Like)
      .where(eq(Like.slug, entry.id))
    postLikesCount = Number(countVal)
  } catch {
    postLikesCount = 0
  }
}

const { Content, headings } = await render(entry)
const headingsArray = buildHierarchy(headings)

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<InnerLayout
  subtitle={entry.data.subtitle}
  meta={{
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.image,
    canonicalURL: canonicalURL.href,
  }}
>
  <article
    class="post region wrapper"
    data-article="true"
    style="--measure: 85ch"
    id="main"
    data-direction="rtl"
  >
    {
      headingsArray && headingsArray.length > 0 && (
        <noscript>
          <nav class="post__toc-fallback case-panel flow" aria-label="Table of contents">
            <h2 class="post__toc-fallback-title">Table of contents</h2>
            <ul class="post__toc-fallback-list list-none pl-zero space-y-2xs">
              {headingsArray.map((heading) => <TableOfContents heading={heading} />)}
            </ul>
          </nav>
        </noscript>
      )
    }
    <div class="post__row">
      <div class="post__content flow prose">
        <Content components={mdxComponents} />
      </div>
    </div>
    {
      headingsArray && headingsArray.length > 0 && (
        <FloatingTableOfContents headings={headingsArray} />
      )
    }
    <div
      class="flex flow flow-space-2xs flex-col justify-center items-center mt-s"
    >
      <p class="font-display font-bold">Helpful?</p>
      <Likes count={postLikesCount} slug={entry.id} />
    </div>
  </article>
</InnerLayout>
